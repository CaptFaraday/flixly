{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation testing config. Run with: npm run mutate. Mutates only the modules we have unit tests for so the suite doesn't blow up. As coverage expands, add more globs to mutate.",
  "packageManager": "npm",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vite.config.ts"
  },
  "mutate": [
    "src/nav/spatial.ts",
    "src/nav/useFocusable.ts",
    "src/sources/parse-name.ts",
    "src/sources/picker.ts",
    "src/sources/capabilities.ts",
    "src/sources/realdebrid.ts",
    "src/data/tmdb.ts",
    "src/state/persistence.ts",
    "backend/lib/score.ts",
    "backend/lib/digital-release.ts",
    "backend/sources/tmdb.ts",
    "backend/sources/omdb.ts"
  ],
  "reporters": ["html", "clear-text", "progress"],
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "coverageAnalysis": "perTest",
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": null
  },
  "concurrency": 4,
  "timeoutMS": 60000,
  "tempDirName": ".stryker-tmp",
  "logLevel": "info"
}
