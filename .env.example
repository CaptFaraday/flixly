# Copy to .env and fill in your own values. Do NOT commit .env (it is gitignored).
# These same values get added to the GitHub repo as Action secrets for CI.

# TMDb v4 "API Read Access Token" — get one at https://www.themoviedb.org/settings/api
TMDB_TOKEN=

# TMDb v3 API key (same page) — fallback for v3-only endpoints
TMDB_API_KEY=

# OMDb free-tier key — get one at http://www.omdbapi.com/apikey.aspx (must activate via email)
OMDB_API_KEY=

# Same as TMDB_API_KEY, exposed to the TV app bundle for live search
VITE_TMDB_API_KEY=
